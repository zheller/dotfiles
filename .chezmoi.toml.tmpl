{{- $home := .chezmoi.homeDir -}}
{{- $name := promptStringOnce . "identity.name" "Full name" -}}
{{- $email := promptStringOnce . "identity.email" "Email address" -}}
{{- $aiToolbox := promptStringOnce . "paths.ai_toolbox" "Path to ai-toolbox" -}}
{{- $icloudRoot := promptStringOnce . "paths.icloud_root" "Path to iCloud root (optional)" "" -}}
{{- $cloudbox := promptStringOnce . "paths.cloudbox" "Path to cloudbox (optional)" "" -}}
{{- $opVault := promptStringOnce . "onepassword.vault" "1Password vault for shared secrets" -}}
# Generated by chezmoi from .chezmoi.toml.tmpl.
# Edit ~/.config/chezmoi/chezmoi.toml locally to update private values.

[data.identity]
name = {{ $name | quote }}
email = {{ $email | quote }}

[data.paths]
ai_toolbox = {{ $aiToolbox | quote }}
{{- if $icloudRoot }}
icloud_root = {{ $icloudRoot | quote }}
{{- end }}
{{- if $cloudbox }}
cloudbox = {{ $cloudbox | quote }}
{{- end }}

[data.onepassword]
vault = {{ $opVault | quote }}

[data.homebrew]
# Keep additional/private package inventory here.
# The committed Brewfile already includes the base toolchain required by these dotfiles.
taps = []
brews = []
casks = []
vscode = []
go = []
uv = []
